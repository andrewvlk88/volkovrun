# Garmin Connect credentials — לעולם לא להעלות ל-git!
# העתק קובץ זה ל-.env ומלא את הערכים
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password

# אופציונלי — נתיב לשמירת טוקנים (ברירת מחדל: ./tokens)
# GARMIN_TOKEN_DIR=./tokens

# אופציונלי — נתיב מסד נתונים (ברירת מחדל: ./runs.db)
# DATABASE_URL=./runs.db